# =============================================================================
# Cohort Connect — environment variables (example only; no real secrets here)
# =============================================================================
# Copy to `.env` in the project root (same folder as package.json). That file is
# gitignored — never commit real keys.
#
# Restart `npm run dev` after creating or editing `.env`.

# Supabase — Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: Next.js public names (same values). Usually unnecessary because
# `next.config.ts` copies SUPABASE_* into NEXT_PUBLIC_* at build time.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Database: run `supabase/migrations/001_student_profiles.sql` in the Supabase
# SQL editor so student sign-up can write to `student_profiles`. After 001–003,
# run `004_student_profile_survey.sql` so the student profile survey can save
# and lock answers. Run `005_submit_student_profile_survey_rpc.sql` so survey
# submit uses an RLS-safe RPC (avoids infinite recursion on update).
# -----------------------------------------------------------------------------
